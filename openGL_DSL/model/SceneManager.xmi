          xsi:type="openGL_DSL:Rectangulo"
          Ancho="300.0"
          Alto="200.0"
          Rellenar="false">
        <Color
            R="1.0"
            A="1.0"/>
      </abs_entity>
    </nodo>
  </scenes>
  <scenes Name="circulos"
      Visible="false">
    <nodo Name="circulos">
      <abs_entity
          xsi:type="openGL_DSL:Circulo"
          Radio="100.0"/>
      <abs_entity
