<?xml version="1.0" encoding="UTF-8"?>
<openGL_DSL:SceneManager
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:openGL_DSL="http://www.example.org/openGL_DSL"
    WinW="800"
    WinH="600">
  <viewport/>
  <camera/>
  <scenes Name="ejes">
    <nodo Name="ejes">
      <nodo
          Name="ejes2">
        <abs_entity
            xsi:type="openGL_DSL:EjesRGB"
            Lenght="400.0"/>
        <posicion
            X="-200.0"
            Y="-200.0"/>
        <rotacion
            Y="-45.0"/>
        <escala
            X="2.0"
            Y="1.0"
            Z="1.0"/>
      </nodo>
      <abs_entity
          xsi:type="openGL_DSL:EjesRGB"
          Lenght="400.0"/>
      <posicion
          X="100.0"/>
      <rotacion/>
      <escala
          X="1.0"
          Y="1.0"
          Z="1.0"/>
    </nodo>
  </scenes>
  <scenes Name="extra">
    <nodo Name="extra">
      <abs_entity
          xsi:type="openGL_DSL:EjesRGB"
          Lenght="400.0"/>
      <posicion/>
      <rotacion/>
      <escala
          X="1.0"
          Y="1.0"
          Z="1.0"/>
    </nodo>
  </scenes>
</openGL_DSL:SceneManager>
