<?xml version="1.0" encoding="UTF-8"?>
<openGL_DSL:SceneManager
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:openGL_DSL="http://www.example.org/openGL_DSL">
  <viewport/>
  <camera/>
  <scenes Name="eje">
    <nodo Name="eje">
      <abs_entity
          xsi:type="openGL_DSL:EjesRGB"
          Lenght="400.0"/>
    </nodo>
  </scenes>
  <scenes Name="poligonos"
      Visible="false">
    <nodo Name="poligonos">
      <nodo
          Name="triangulo">
        <abs_entity
            xsi:type="openGL_DSL:PoligonoRegular"
            NumVertices="3"
            Radio="100.0">
          <Color
              R="1.0"
              A="1.0"/>
        </abs_entity>
      </nodo>
      <nodo
          Name="cuadrado">
        <abs_entity
            xsi:type="openGL_DSL:PoligonoRegular"
            NumVertices="4"
            Radio="200.0"
            Rellenar="true">
          <Color
              G="1.0"
              A="1.0"/>
        </abs_entity>
      </nodo>
      <nodo
          Name="pentagono">
        <abs_entity
            xsi:type="openGL_DSL:PoligonoRegular"
            NumVertices="5"
            Radio="300.0">
          <Color
              B="1.0"
              A="1.0"/>
        </abs_entity>
      </nodo>
      <nodo
          Name="hexagono">
        <abs_entity
            xsi:type="openGL_DSL:PoligonoRegular"
            NumVertices="6"
            Radio="400.0"
            Rellenar="true">
          <Color
              R="1.0"
              G="1.0"
              A="1.0"/>
        </abs_entity>
      </nodo>
    </nodo>
  </scenes>
  <scenes Name="rectangulos"
      Visible="false">
    <nodo Name="rectangulos">
      <abs_entity
          xsi:type="openGL_DSL:Rectangulo"
          Ancho="100.0"
          Alto="50.0"
          Rellenar="false">
        <Color
            A="1.0"/>
      </abs_entity>
      <abs_entity
          xsi:type="openGL_DSL:Rectangulo"
          Ancho="200.0"
          Alto="100.0"/>
