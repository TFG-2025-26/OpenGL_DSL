<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="openGL_DSL" nsURI="http://www.example.org/openGL_DSL" nsPrefix="openGL_DSL">
  <eClassifiers xsi:type="ecore:EClass" name="SceneManager">
    <eOperations name="run"/>
    <eOperations name="close"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="WinId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="WinW" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"
        defaultValueLiteral="800"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="WinH" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"
        defaultValueLiteral="600"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="viewport" eType="#//ViewPort"
        containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="camera" eType="#//Camera"
        containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="scenes" upperBound="-1"
        eType="#//Scene" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mStop" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"
        defaultValueLiteral="False">
      <eAnnotations/>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ViewPort">
    <eOperations name="upload"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="xLeft" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="yBolt" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="xWidth" eType="#//GLsizei"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="yHeight" eType="#//GLsizei"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Camera">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mEye" eType="#//vec3"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mLook" eType="#//vec3"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mUp" eType="#//vec3"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="modelViewMat" eType="#//mat4"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mProjMat" eType="#//mat4"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mNearVal" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mFarVal" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"
        defaultValueLiteral="10000"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Scene">
    <eOperations name="addNode"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="Name" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="Visible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"
        defaultValueLiteral="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="nodo" upperBound="-1" eType="#//Node"
        containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Light" abstract="true" interface="true">
    <eOperations name="uploadL">
      <eParameters name="modelViewMat" eType="#//mat4"/>
    </eOperations>
    <eOperations name="disable"/>
    <eOperations name="enable"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="cont" eType="#//GLuint"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id" eType="#//GLuint" iD="true"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="posDIr" eType="#//vec4"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="ambient" eType="#//Vector4"
