        containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="DirLight" eSuperTypes="#//Light"/>
  <eClassifiers xsi:type="ecore:EClass" name="PosLight" eSuperTypes="#//Light">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="kc" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EFloat"
