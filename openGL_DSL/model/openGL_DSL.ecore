  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="QuadricEntity" abstract="true" eSuperTypes="#//Abs_Entity">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="q" eType="#//GLquadricObj"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Material">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="ambient" eType="#//vec4"/>
