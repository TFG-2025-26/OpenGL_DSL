    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nNumVertices" eType="#//GLuint"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="vColors" eType="#//vec4"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="vVertices" eType="#//vec3"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="vTexCoords" eType="#//vec2"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="vNormals" eType="#//vec3"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="MbR" eSuperTypes="#//IndexMesh">
    <eOperations name="generateIndexMbR" eType="#//MbR">
      <eParameters name="n" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
      <eParameters name="m" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
      <eParameters name="perfil" eType="#//vec3"/>
    </eOperations>
