      <body xsi:type="mtl:IfBlock">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    // Renderizando Esfera&#xA;    glColor3f(1.0f, 0.0f, 0.0f); // Color base&#xA;    glutWireSphere(1.0, 20, 20);&#xA;"/>
        <ifExpr xsi:type="ocl.ecore:OperationCallExp">
