    <ownedModuleElement xsi:type="mtl:Template" name="generateSceneLogic" visibility="Public">
      <body xsi:type="mtl:ForBlock">
        <body xsi:type="mtl:TemplateInvocation" definition="/0/generateNode">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
          <argument xsi:type="ocl.ecore:VariableExp" name="n" referredVariable="/0/generateSceneLogic/%/n">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </argument>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;"/>
        <loopVariable name="n">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
        </loopVariable>
        <iterSet xsi:type="ocl.ecore:PropertyCallExp" eType="/6/OrderedSet(Node)">
          <source xsi:type="ocl.ecore:VariableExp" name="aScene" referredVariable="/0/generateSceneLogic/aScene">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Scene"/>
          </source>
          <referredProperty xsi:type="ecore:EReference" href="http://www.example.org/openGL_DSL#//Scene/nodo"/>
        </iterSet>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="Scene* Scene_"/>
      <body xsi:type="ocl.ecore:PropertyCallExp">
        <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        <source xsi:type="ocl.ecore:VariableExp" name="aScene" referredVariable="/0/generateSceneLogic/aScene">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Scene"/>
        </source>
        <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//Scene/Name"/>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="(){&#xD;&#xA;    Scene* scene= new Scene();&#xD;&#xA;"/>
      <body xsi:type="mtl:ForBlock">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    scene->addNode(Node_"/>
        <body xsi:type="ocl.ecore:PropertyCallExp">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
          <source xsi:type="ocl.ecore:VariableExp" name="n" referredVariable="/0/generateSceneLogic/%.4/n">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </source>
          <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//Node/Name"/>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="());&#xD;&#xA;"/>
        <loopVariable name="n">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
        </loopVariable>
        <iterSet xsi:type="ocl.ecore:PropertyCallExp" eType="/6/OrderedSet(Node)">
          <source xsi:type="ocl.ecore:VariableExp" name="aScene" referredVariable="/0/generateSceneLogic/aScene">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Scene"/>
          </source>
          <referredProperty xsi:type="ecore:EReference" href="http://www.example.org/openGL_DSL#//Scene/nodo"/>
        </iterSet>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    return scene;&#xD;&#xA;}"/>
      <parameter name="aScene">
        <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Scene"/>
      </parameter>
    </ownedModuleElement>
    <ownedModuleElement xsi:type="mtl:Template" name="generateNode" visibility="Public">
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;"/>
      <body xsi:type="mtl:ForBlock">
        <body xsi:type="mtl:TemplateInvocation" definition="/0/generateNode">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
          <argument xsi:type="ocl.ecore:VariableExp" name="nd" referredVariable="/0/generateNode/%.1/nd">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </argument>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;"/>
        <loopVariable name="nd">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
        </loopVariable>
        <iterSet xsi:type="ocl.ecore:PropertyCallExp" eType="/6/OrderedSet(Node)">
          <source xsi:type="ocl.ecore:VariableExp" name="n" referredVariable="/0/generateNode/n">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </source>
          <referredProperty xsi:type="ecore:EReference" href="http://www.example.org/openGL_DSL#//Node/nodo"/>
        </iterSet>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;Node* Node_"/>
      <body xsi:type="ocl.ecore:PropertyCallExp">
        <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        <source xsi:type="ocl.ecore:VariableExp" name="n" referredVariable="/0/generateNode/n">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
        </source>
        <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//Node/Name"/>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="() {&#xD;&#xA;    Node* node = new Node(&#xD;&#xA;        dvec3(0, 0, 0),//pos&#xD;&#xA;        dvec3(0, 0, 0),//rot&#xD;&#xA;        dvec3(1, 1, 1)//esc&#xD;&#xA;    );&#xD;&#xA;&#xD;&#xA;"/>
      <body xsi:type="mtl:ForBlock">
        <body xsi:type="mtl:IfBlock">
          <body xsi:type="mtl:LetBlock">
            <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    node->addEntity(new EjesRGB("/>
            <body xsi:type="ocl.ecore:PropertyCallExp">
              <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Real"/>
              <source xsi:type="ocl.ecore:VariableExp" name="e" referredVariable="/0/generateNode/%.5/%/%/e">
                <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//EjesRGB"/>
              </source>
              <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//EjesRGB/Lenght"/>
            </body>
            <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="));&#xD;&#xA;"/>
            <letVariable name="e">
              <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//EjesRGB"/>
              <initExpression xsi:type="ocl.ecore:OperationCallExp">
                <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//EjesRGB"/>
                <source xsi:type="ocl.ecore:VariableExp" name="ent" referredVariable="/0/generateNode/%.5/ent">
                  <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Abs_Entity"/>
                </source>
                <argument xsi:type="ocl.ecore:TypeExp" eType="/30/EjesRGB">
                  <referredType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//EjesRGB"/>
                </argument>
                <referredOperation xsi:type="ecore:EOperation" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/OclAny_Class/oclAsType"/>
              </initExpression>
            </letVariable>
          </body>
          <ifExpr xsi:type="ocl.ecore:OperationCallExp">
            <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Boolean"/>
            <source xsi:type="ocl.ecore:VariableExp" name="ent" referredVariable="/0/generateNode/%.5/ent">
              <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Abs_Entity"/>
            </source>
            <argument xsi:type="ocl.ecore:TypeExp" eType="/30/EjesRGB">
              <referredType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//EjesRGB"/>
            </argument>
            <referredOperation xsi:type="ecore:EOperation" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/OclAny_Class/oclIsKindOf"/>
          </ifExpr>
          <elseIf>
            <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    node->addEntity(new Esfera()); &#xD;&#xA;"/>
            <ifExpr xsi:type="ocl.ecore:OperationCallExp">
              <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Boolean"/>
              <source xsi:type="ocl.ecore:VariableExp" name="ent" referredVariable="/0/generateNode/%.5/ent">
                <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Abs_Entity"/>
              </source>
              <argument xsi:type="ocl.ecore:TypeExp" eType="/30/Esfera">
                <referredType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Esfera"/>
              </argument>
              <referredOperation xsi:type="ecore:EOperation" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/OclAny_Class/oclIsKindOf"/>
            </ifExpr>
          </elseIf>
          <elseIf>
            <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    node->addEntity(new Rectangulo());&#xD;&#xA;"/>
            <ifExpr xsi:type="ocl.ecore:OperationCallExp">
              <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Boolean"/>
              <source xsi:type="ocl.ecore:VariableExp" name="ent" referredVariable="/0/generateNode/%.5/ent">
                <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Abs_Entity"/>
              </source>
              <argument xsi:type="ocl.ecore:TypeExp" eType="/30/Rectangulo">
                <referredType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Rectangulo"/>
              </argument>
              <referredOperation xsi:type="ecore:EOperation" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/OclAny_Class/oclIsKindOf"/>
            </ifExpr>
          </elseIf>
        </body>
        <loopVariable name="ent">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Abs_Entity"/>
        </loopVariable>
        <iterSet xsi:type="ocl.ecore:PropertyCallExp" eType="/6/OrderedSet(Abs_Entity)">
          <source xsi:type="ocl.ecore:VariableExp" name="n" referredVariable="/0/generateNode/n">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </source>
          <referredProperty xsi:type="ecore:EReference" href="http://www.example.org/openGL_DSL#//Node/abs_entity"/>
        </iterSet>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    // Generar hijos recursivamente&#xD;&#xA;"/>
      <body xsi:type="mtl:ForBlock">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    node->addNode(Node_"/>
        <body xsi:type="ocl.ecore:PropertyCallExp">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
          <source xsi:type="ocl.ecore:VariableExp" name="child" referredVariable="/0/generateNode/%.7/child">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </source>
          <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//Node/Name"/>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="());&#xD;&#xA;"/>
        <loopVariable name="child">
          <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
        </loopVariable>
        <iterSet xsi:type="ocl.ecore:PropertyCallExp" eType="/6/OrderedSet(Node)">
          <source xsi:type="ocl.ecore:VariableExp" name="n" referredVariable="/0/generateNode/n">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
          </source>
          <referredProperty xsi:type="ecore:EReference" href="http://www.example.org/openGL_DSL#//Node/nodo"/>
        </iterSet>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;    return node;&#xD;&#xA;}"/>
      <parameter name="n">
        <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Node"/>
      </parameter>
    </ownedModuleElement>
