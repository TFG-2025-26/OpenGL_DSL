[comment encoding = UTF-8 /]
[module sceneElements('http://www.example.org/openGL_DSL')]

[import openGL_acceleo_impl::files::entityFile /]

[template public generateSceneLogic(aScene : Scene)]
[for (n : Node | aScene.nodo)]
[generateNode(n)/]
[/for]

Scene* Scene_[aScene.Name/](){
    Scene* scene= new Scene();
[for (n : Node | aScene.nodo)]
    scene->addNode(Node_[n.Name/]());
[/for]
    scene->setVisible([aScene.Visible/]);
    return scene;
}
[/template]

[template public generateNode(n : Node)]

[for (nd : Node | n.nodo)]
[generateNode(nd)/]
[/for]

Node* Node_[n.Name/]() {
    Node* node = new Node(
[if (n.posicion <> null)]
        dvec3([n.posicion.X/], [n.posicion.Y/], [n.posicion.Z/]),//pos
[else]
        dvec3(0.0, 0.0, 0.0),//pos
[/if]
[if (n.rotacion <> null)]
        dvec3([n.rotacion.X/], [n.rotacion.Y/], [n.rotacion.Z/]),//rot
[else]
        dvec3(0.0, 0.0, 0.0),//rot
[/if]
[if (n.escala <> null)]
        dvec3([n.escala.X/], [n.escala.Y/], [n.escala.Z/])//esc
[else]
        dvec3(1.0, 1.0, 1.0)//esc
[/if]
    );

[for (lig : Light | n.light)]
[if (lig.oclIsKindOf(DirLight))]
[let l : DirLight = lig.oclAsType(DirLight)]
    auto l[n.light->indexOf(lig)/] = new DirLight();
[if (l.direccion <> null)]
    l[n.light->indexOf(lig)/]->setPosDir(fvec3([l.direccion.X/],[l.direccion.Y/],[l.direccion.Z/]));
[/if]
[/let]
[elseif (lig.oclIsKindOf(SpotLight))]
[let l : SpotLight = lig.oclAsType(SpotLight)]
    auto l[n.light->indexOf(lig)/] = new SpotLight();
[if (lig.direccion <> null)]
    l[n.light->indexOf(lig)/]->setSpot(fvec3([lig.direccion.X/],[lig.direccion.Y/],[lig.direccion.Z/]),[l.cutoff/],[l.exp/]);
[else]
    l[n.light->indexOf(lig)/]->setSpot(fvec3(0,0,-1),[l.cutoff/],[l.exp/]);
[/if]
    l[n.light->indexOf(lig)/]->setAtte([l.kc/],[l.kl/],[l.kq/]);
[/let]
[elseif (lig.oclIsKindOf(PosLight))]
[let l : PosLight = lig.oclAsType(PosLight)]
    auto l[n.light->indexOf(lig)/] = new PosLight();
[if (lig.direccion <> null)]
    l[n.light->indexOf(lig)/]->setPosDir(fvec3([lig.direccion.X/],[lig.direccion.Y/],[lig.direccion.Z/]));
[/if]
    l[n.light->indexOf(lig)/]->setAtte([l.kc/],[l.kl/],[l.kq/]);

[/let]
[/if]
    node->addLight(l[n.light->indexOf(lig)/]);
[if (lig.ambient <> null)]
    l[n.light->indexOf(lig)/]->setAmb(fvec4([lig.ambient.R/],[lig.ambient.G/],[lig.ambient.B/],[lig.ambient.A/]));
[/if]
[if (lig.difusse <> null)]
    l[n.light->indexOf(lig)/]->setDiff(fvec4([lig.difusse.R/],[lig.difusse.G/],[lig.difusse.B/],[lig.difusse.A/]));
[/if]
[if (lig.specular <> null)]
    l[n.light->indexOf(lig)/]->setSpec(fvec4([lig.specular.R/],[lig.specular.G/],[lig.specular.B/],[lig.specular.A/]));
[/if]
[/for]

[for (ent : Abs_Entity | n.abs_entity)]
[if (ent.oclIsKindOf(EjesRGB))]
    [let e : EjesRGB = ent.oclAsType(EjesRGB)]
    auto e[n.abs_entity->indexOf(ent)/] = new EjesRGB([e.Lenght/]);
[/let] 
[elseif (ent.oclIsKindOf(PoligonoRegular))]
    [let e : PoligonoRegular = ent.oclAsType(PoligonoRegular)]
    auto e[n.abs_entity->indexOf(ent)/] = new PoligonoRegular([e.NumVertices/],[e.Radio/],[e.Rellenar/],[ent.TexturaRepeticionAncho/],[ent.TexturaRepeticionAlto/]);
[/let]
[elseif (ent.oclIsKindOf(Rectangulo))]
    [let e : Rectangulo = ent.oclAsType(Rectangulo)]
    auto e[n.abs_entity->indexOf(ent)/] = new Rectangulo([e.Ancho/],[e.Alto/],[e.Rellenar/],[ent.TexturaRepeticionAncho/],[ent.TexturaRepeticionAlto/]);
[/let]
[elseif (ent.oclIsKindOf(Circulo))]
    [let e : Circulo = ent.oclAsType(Circulo)]
    auto e[n.abs_entity->indexOf(ent)/] = new Circulo([e.Radio/],[e.Rellenar/],[ent.TexturaRepeticionAncho/],[ent.TexturaRepeticionAlto/]);
[/let]
[elseif (ent.oclIsKindOf(Esfera))]
    [let e : Esfera = ent.oclAsType(Esfera)]
    auto e[n.abs_entity->indexOf(ent)/] = new Sphere([e.Radio/]);
[/let]
[elseif (ent.oclIsKindOf(Cilindro))]
    [let e : Cilindro = ent.oclAsType(Cilindro)]
    auto e[n.abs_entity->indexOf(ent)/] = new Cylinder([e.RadioBase/],[e.RadioTope/],[e.Altura/]);
[/let]
[elseif (ent.oclIsKindOf(Disco))]
    [let e : Disco = ent.oclAsType(Disco)]
    auto e[n.abs_entity->indexOf(ent)/] = new Disk([e.RadioInterno/],[e.RadioExterno/]);
[/let]
[elseif (ent.oclIsKindOf(DiscoParcial))]
    [let e : DiscoParcial = ent.oclAsType(DiscoParcial)]
    auto e[n.abs_entity->indexOf(ent)/] = new PartialDisk([e.RadioInterno/],[e.RadioExterno/],[e.AnguloInicio/],[e.AmplitudAngulo/]);
[/let]
[elseif (ent.oclIsKindOf(Cubo))]
    [let e : Cubo = ent.oclAsType(Cubo)]
    auto e[n.abs_entity->indexOf(ent)/] = new IndexedBox([e.Lenght/]);
[/let]
[elseif (ent.oclIsKindOf(Toroide))]
    [let e : Toroide = ent.oclAsType(Toroide)]
    auto e[n.abs_entity->indexOf(ent)/] = new Toroid([e.RadioAnillo/],[e.RadioCentro/]);
[/let]
[/if]
    node->addEntity(e[n.abs_entity->indexOf(ent)/]);
[if (ent.Color <> null)]
    e[n.abs_entity->indexOf(ent)/]->setColor(dvec4([ent.Color.R/],[ent.Color.G/],[ent.Color.B/],[ent.Color.A/]));
[/if]
[if (ent.FrontTexture <> null)]
    Texture* frontTexture[n.abs_entity->indexOf(ent)/] = new Texture();
	frontTexture[n.abs_entity->indexOf(ent)/]->load("[ent.FrontTexture.Textura/]", [ent.FrontTexture.Alfa/]);
    e[n.abs_entity->indexOf(ent)/]->setFrontTexture(frontTexture[n.abs_entity->indexOf(ent)/]);
[/if]
[if (ent.BackTexture <> null)]
    Texture* backTexture[n.abs_entity->indexOf(ent)/] = new Texture();
	backTexture[n.abs_entity->indexOf(ent)/]->load("[ent.BackTexture.Textura/]", [ent.BackTexture.Alfa/]);
    e[n.abs_entity->indexOf(ent)/]->setBackTexture(backTexture[n.abs_entity->indexOf(ent)/]);
[/if]
[if (ent.material <> null)]
    Material* material[n.abs_entity->indexOf(ent)/] = new Material();
[if (ent.material.ambient <> null)]
    material[n.abs_entity->indexOf(ent)/]->setAmb(fvec4([ent.material.ambient.R/],[ent.material.ambient.G/],[ent.material.ambient.B/],[ent.material.ambient.A/]));
[/if]
[if (ent.material.difusse <> null)]
    material[n.abs_entity->indexOf(ent)/]->setDiff(fvec4([ent.material.difusse.R/],[ent.material.difusse.G/],[ent.material.difusse.B/],[ent.material.difusse.A/]));
[/if]
[if (ent.material.specular <> null)]
    material[n.abs_entity->indexOf(ent)/]->setSpec(fvec4([ent.material.specular.R/],[ent.material.specular.G/],[ent.material.specular.B/],[ent.material.specular.A/]));
[/if]
    material[n.abs_entity->indexOf(ent)/]->setExpF([ent.material.expF/]);
    e[n.abs_entity->indexOf(ent)/]->setMaterial(material[n.abs_entity->indexOf(ent)/]);
[/if]
[/for]
    // Generar hijos recursivamente
[for (child : Node | n.nodo)]
    node->addNode(Node_[child.Name/]());
[/for]

    return node;
}
[/template]