        </charset>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xA;"/>
      <body xsi:type="mtl:FileBlock" openMode="OverWrite">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#include &quot;Camera.h&quot;&#xA;#include &lt;glm/gtc/matrix_transform.hpp>&#xA;#include &lt;glm/gtc/type_ptr.hpp>&#xA;&#xA;Camera::Camera(Viewport* vp) &#xA;    : mViewPort(vp), mViewMat(1.0), mProjMat(1.0) {&#xA;    mNear = "/>
        <body xsi:type="ocl.ecore:PropertyCallExp">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Real"/>
          <source xsi:type="ocl.ecore:VariableExp" name="aCam" referredVariable="/0/generateCamera/aCam">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Camera"/>
          </source>
          <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//Camera/mNearVal"/>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol=";&#xA;    mFar = "/>
        <body xsi:type="ocl.ecore:PropertyCallExp">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Real"/>
          <source xsi:type="ocl.ecore:VariableExp" name="aCam" referredVariable="/0/generateCamera/aCam">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Camera"/>
          </source>
          <referredProperty xsi:type="ecore:EAttribute" href="http://www.example.org/openGL_DSL#//Camera/mFarVal"/>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol=";&#xA;}&#xA;&#xA;void Camera::setVM() {&#xA;    // Valores por defecto inspirados en tu codigo fuente&#xA;    glm::dvec3 eye(0, 0, 500);&#xA;    glm::dvec3 look(0, 0, 0);&#xA;    glm::dvec3 up(0, 1, 0);&#xA;    mViewMat = glm::lookAt(eye, look, up);&#xA;}&#xA;&#xA;void Camera::uploadVM() const {&#xA;    glMatrixMode(GL_MODELVIEW);&#xA;    glLoadMatrixd(glm::value_ptr(mViewMat));&#xA;}&#xA;"/>
        <fileUrl xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="Camera.cpp">
