        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#ifndef _H_Camera_H_&#xA;#define _H_Camera_H_&#xA;&#xA;#include &lt;glm/glm.hpp>&#xA;#include &quot;Viewport.h&quot;&#xA;&#xA;class Camera {&#xA;public:&#xA;    Camera(Viewport* vp);&#xA;    void uploadVM() const;&#xA;    void setVM();&#xA;&#xA;private:&#xA;    glm::dmat4 mViewMat;&#xA;    glm::dmat4 mProjMat;&#xA;    double mNear, mFar;&#xA;    Viewport* mViewPort;&#xA;};&#xA;#endif&#xA;"/>
