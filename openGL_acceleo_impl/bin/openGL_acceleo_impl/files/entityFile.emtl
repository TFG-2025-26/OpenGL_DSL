    <ownedModuleElement xsi:type="mtl:Template" name="generateEsfera" visibility="Public">
      <body xsi:type="mtl:FileBlock" openMode="OverWrite">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#ifndef _H_Esfera_H_&#xA;#define _H_Esfera_H_&#xA;&#xA;#include &quot;Abs_Entity.h&quot;&#xA;&#xA;class Esfera : public Abs_Entity {&#xA;public:&#xA;    Esfera(double r = 1.0) : mRadius(r) {}&#xA;    virtual ~Esfera() = default;&#xA;    virtual void render() override;&#xA;private:&#xA;    double mRadius;&#xA;};&#xA;#endif&#xA;"/>
        <fileUrl xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="Esfera.h">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </fileUrl>
        <charset xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="UTF-8">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </charset>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xA;"/>
      <body xsi:type="mtl:FileBlock" openMode="OverWrite">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#include &quot;Esfera.h&quot;&#xA;&#xA;void Esfera::render() {&#xA;    // Estilo de renderizado segun tu codigo de ejemplo&#xA;    glPushMatrix();&#xA;    // Aqui se podria añadir glColor o glTranslate segun el Nodo&#xA;    glutWireSphere(mRadius, 20, 20);&#xA;    glPopMatrix();&#xA;}&#xA;"/>
        <fileUrl xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="Esfera.cpp">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </fileUrl>
        <charset xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="UTF-8">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </charset>
      </body>
      <parameter name="e">
        <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Esfera"/>
      </parameter>
    </ownedModuleElement>
    <ownedModuleElement xsi:type="mtl:Template" name="generateRectangulo" visibility="Public">
      <body xsi:type="mtl:FileBlock" openMode="OverWrite">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#ifndef _H_Rectangulo_H_&#xA;#define _H_Rectangulo_H_&#xA;&#xA;#include &quot;Abs_Entity.h&quot;&#xA;&#xA;class Rectangulo : public Abs_Entity {&#xA;public:&#xA;    Rectangulo() {}&#xA;    virtual ~Rectangulo() = default;&#xA;    virtual void render() override;&#xA;};&#xA;#endif&#xA;"/>
        <fileUrl xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="Rectangulo.h">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </fileUrl>
        <charset xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="UTF-8">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </charset>
      </body>
      <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xA;"/>
      <body xsi:type="mtl:FileBlock" openMode="OverWrite">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#include &quot;Rectangulo.h&quot;&#xA;&#xA;void Rectangulo::render() {&#xA;    glBegin(GL_QUADS);&#xA;        glVertex2f(-0.5f, -0.5f);&#xA;        glVertex2f( 0.5f, -0.5f);&#xA;        glVertex2f( 0.5f,  0.5f);&#xA;        glVertex2f(-0.5f,  0.5f);&#xA;    glEnd();&#xA;}&#xA;"/>
        <fileUrl xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="Rectangulo.cpp">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </fileUrl>
        <charset xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="UTF-8">
          <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
        </charset>
      </body>
      <parameter name="r">
        <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Rectangulo"/>
      </parameter>
    </ownedModuleElement>
