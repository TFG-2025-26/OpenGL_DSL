        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol=" };&#xA;&#xA;&#x9;&#x9;auto n = dvec3(0, 0, 0);&#xA;&#x9;&#x9;for (int j = 0; j &lt; 3; j++) {&#xA;&#x9;&#x9;&#x9;auto verticeActual = vVertices"/>
