        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol=" data_;&#xA;   data_ = nullptr;&#xA;   width_ = 0;&#xA;   height_ = 0;&#xA;}&#xA;//-------------------------------------------------------------------------------------------&#xA;PixMap32RGBA PixMap32RGBA::clone()  // throw(std::exception, std::bad_alloc)&#xA;{&#xA;&#x9;PixMap32RGBA clon;&#xA;&#x9;clon.reserve(width(), height());&#xA;&#x9;&#xA;&#x9;for (GLsizei i = 0; i&lt; width_ * height_; i++)&#xA;&#x9;&#x9;clon.data_"/>
