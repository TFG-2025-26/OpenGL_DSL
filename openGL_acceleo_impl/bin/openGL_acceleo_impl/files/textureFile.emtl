        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="; }&#xA;&#xA;   void set_pixel(const GLsizei x, const GLsizei y, const rgba_color &amp; rgba) noexcept&#xA;   { data_"/>
