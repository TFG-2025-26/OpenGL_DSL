      <body xsi:type="mtl:FileBlock" openMode="OverWrite">
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="#include &lt;GL/freeglut.h>&#xD;&#xA;#include &lt;glm/glm.hpp>   // OpenGL Mathematics&#xD;&#xA;#include &lt;iostream>&#xD;&#xA;&#xD;&#xA;#include &quot;Viewport.h&quot;&#xD;&#xA;#include &quot;Camera.h&quot;&#xD;&#xA;#include &quot;Scene.h&quot;&#xD;&#xA;#include &lt;vector>&#xD;&#xA;&#xD;&#xA;using namespace std;&#xD;&#xA;&#xD;&#xA;// Variables globales&#xD;&#xA;Viewport* viewport = nullptr;&#xD;&#xA;Camera* camera = nullptr;&#xD;&#xA;vector&lt;Scene*> scenes;&#xD;&#xA;&#xD;&#xA;glm::dvec2 mMouseCoord;&#xD;&#xA;int mMouseButt;&#xD;&#xA;&#xD;&#xA;"/>
        <body xsi:type="mtl:ForBlock">
          <body xsi:type="mtl:TemplateInvocation">
            <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
            <definition href="../common/sceneElements.emtl#/0/generateSceneLogic"/>
            <argument xsi:type="ocl.ecore:VariableExp" name="s" referredVariable="/0/generateElement/%.6/%.1/s">
              <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Scene"/>
            </argument>
          </body>
          <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;"/>
          <loopVariable name="s">
            <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//Scene"/>
          </loopVariable>
          <iterSet xsi:type="ocl.ecore:PropertyCallExp" eType="/10/OrderedSet(Scene)">
            <source xsi:type="ocl.ecore:VariableExp" name="aSM" referredVariable="/0/generateElement/aSM">
              <eType xsi:type="ecore:EClass" href="http://www.example.org/openGL_DSL#//SceneManager"/>
