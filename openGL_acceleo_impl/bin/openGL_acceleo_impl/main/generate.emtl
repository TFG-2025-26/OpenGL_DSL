          </iterSet>
        </body>
        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xA;    init();&#xA;    glutDisplayFunc(display);&#xA;    glutMainLoop();&#xA;&#xA;    // Limpieza de memoria&#xA;    for (Abs_Entity* e : entities) delete e;&#xA;    delete camera;&#xA;    delete viewport;&#xA;&#xA;    return 0;&#xA;}&#xA;"/>
