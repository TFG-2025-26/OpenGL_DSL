        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;    // CARGA DE ENTIDADES DESDE EL MODELO XMI&#xD;&#xA;    Scene* sc;&#xD;&#xA;"/>
