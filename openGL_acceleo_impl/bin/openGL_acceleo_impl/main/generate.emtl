          <body xsi:type="mtl:ForBlock">
            <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="        nd = new Node(dvec3(0,0,0), dvec3(0,0,0), dvec3(1,1,1));&#xD;&#xA;"/>
            <body xsi:type="mtl:ForBlock">
              <body xsi:type="mtl:IfBlock">
