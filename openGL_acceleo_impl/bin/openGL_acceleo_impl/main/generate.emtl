                <referredProperty xsi:type="ecore:EReference" href="http://www.example.org/openGL_DSL#//SceneManager/viewport"/>
              </source>
              <referredOperation xsi:type="ecore:EOperation" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/OclAny_Class/oclIsUndefined"/>
            </source>
            <referredOperation xsi:type="ecore:EOperation" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/Boolean_Class/not"/>
          </ifExpr>
        </body>
        <body xsi:type="mtl:IfBlock">
          <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="    camera = new Camera(viewport);&#xD;&#xA;"/>
          <ifExpr xsi:type="ocl.ecore:OperationCallExp">
