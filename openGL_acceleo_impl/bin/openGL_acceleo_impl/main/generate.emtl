        <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;int main(int argc, char** argv) {&#xD;&#xA;    init();&#xD;&#xA;    glutMainLoop();&#xD;&#xA;&#xD;&#xA;    // Limpieza de memoria&#xD;&#xA;    for (Scene* sc : scenes) {&#xD;&#xA;&#x9;delete sc;&#xD;&#xA;&#x9;sc = nullptr;&#xD;&#xA;    }&#xD;&#xA;    delete camera;&#xD;&#xA;    delete viewport;&#xD;&#xA;&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;"/>
        <fileUrl xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="main.cpp">
