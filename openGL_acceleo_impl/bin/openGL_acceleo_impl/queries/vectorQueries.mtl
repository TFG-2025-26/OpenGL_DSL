[comment encoding = UTF-8 /]
[module vectorQueries('http://www.example.org/openGL_DSL')]

[comment Formatea un objeto vec3 para que sea legible en el texto de salida /]
[query public formatVec3(v : vec3) : String = 
    if (v.oclIsUndefined()) then 
        '(0, 0, 0)' 
    else 
        v.toString() 
    endif 
/]

[comment Consulta para saber si una entidad tiene texturas (ejemplo de lógica) /]
[query public hasTextures(e : Abs_Entity) : Boolean = 
    e.texture->size() > 0 
/]