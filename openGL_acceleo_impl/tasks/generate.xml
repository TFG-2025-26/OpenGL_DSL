<?xml version="1.0" encoding="UTF-8"?>
<project default="generate" name="openGL_acceleo_impl">
    <property name="ECLIPSE_HOME" value="../../../eclipse/modeling-2025-09/eclipse"/>
    <property name="ECLIPSE_WORKSPACE" value="../.."/>

    <!-- The classpath with only the dependencies used by the project -->
    <path id="openGL_acceleo_impl.libraryclasspath">
        <pathelement location="${ECLIPSE_WORKSPACE}/openGL_acceleo_impl/bin"/>
    </path>

    <path id="openGL_acceleo_impl.classpath">
        <path refid="openGL_acceleo_impl.libraryclasspath"/>
    </path>

    <!-- The classpath with only the jars available in the plugin folder of Eclipse -->
    <path id="openGL_acceleo_impl.libraryclasspath.alljars">
        <pathelement location="../openGL_acceleo_impl/bin"/>
        <fileset dir="${ECLIPSE_HOME}/plugins/" includes="*.jar"/>
    </path>

    <path id="openGL_acceleo_impl.classpath.alljars">
        <path refid="openGL_acceleo_impl.libraryclasspath.alljars"/>
    </path>

    <!-- The default task with the jars used by this project -->
    <target name="generate">
        <java classname="openGL_acceleo_impl.main.Generate" classpathref="openGL_acceleo_impl.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>

    <!--
        In case of problem you can also try with all the jar available in your Eclipse
        Keep in mind that having two versions of the same jar can create problems
    -->
    <target name="generate.alljars">
        <java classname="openGL_acceleo_impl.main.Generate" classpathref="openGL_acceleo_impl.classpath">
            <arg value="${model}"/>
            <arg value="${target}"/>
        </java>
    </target>
</project>
